#!/usr/bin/env bash
# Open Design CLI wrapper — switches between stable (AUR) and preview (source)
# Set OD_PREVIEW=1 for source-built 0.8.0, or leave unset for AUR 0.7.0
set -euo pipefail

if [[ "${OD_PREVIEW:-0}" == "1" ]]; then
  OD_REPO="${OD_REPO:-$HOME/Documents/code/open-design}"
  OD_DATA_DIR="${OD_DATA_DIR:-$OD_REPO/.od}"
  export OD_DATA_DIR
  export OD_WEB_PORT="${OD_WEB_PORT:-7457}"
  exec node "$OD_REPO/apps/daemon/dist/cli.js" "$@"
else
  if [[ -z "${OD_DATA_DIR:-}" ]]; then
    export OD_DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/open-design"
  fi
  exec /usr/bin/env node "/usr/lib/open-design/apps/daemon/dist/cli.js" "$@"
fi
