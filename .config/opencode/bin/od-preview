#!/usr/bin/env bash
# Open Design 0.8.0 preview — launch from source
# Daemon=7456, Web=7457  (fixed ports for MCP compatibility)
set -e

OD_REPO="${OD_REPO:-$HOME/Documents/code/open-design}"
OD_DAEMON_PORT="${OD_DAEMON_PORT:-7456}"
OD_WEB_PORT="${OD_WEB_PORT:-7457}"
export OD_DATA_DIR="${OD_DATA_DIR:-$OD_REPO/.od}"

cd "$OD_REPO"

start_daemon() {
  echo "Starting daemon on :$OD_DAEMON_PORT..."
  OD_WEB_PORT="$OD_WEB_PORT" setsid -f node apps/daemon/dist/cli.js \
    --port "$OD_DAEMON_PORT" --host 127.0.0.1 > /tmp/od-daemon.log 2>&1
  for i in $(seq 1 20); do
    if curl -sf "http://127.0.0.1:$OD_DAEMON_PORT/api/health" > /dev/null 2>&1; then
      echo "  daemon ready"
      return 0
    fi
    sleep 1
  done
  echo "  daemon failed — check /tmp/od-daemon.log"
  return 1
}

start_web() {
  echo "Starting web on :$OD_WEB_PORT..."
  setsid -f bash -c "cd '$OD_REPO' && pnpm --filter @open-design/web dev --port '$OD_WEB_PORT' > /tmp/od-web.log 2>&1"
  for i in $(seq 1 30); do
    if curl -sf -o /dev/null "http://127.0.0.1:$OD_WEB_PORT" 2>/dev/null; then
      echo "  web ready"
      return 0
    fi
    sleep 1
  done
  echo "  web failed — check /tmp/od-web.log"
  return 1
}

case "${1:-start}" in
  start)
    start_daemon && start_web && echo ""
    echo "  Web UI:  http://127.0.0.1:$OD_WEB_PORT"
    echo "  Daemon:  http://127.0.0.1:$OD_DAEMON_PORT"
    ;;
  daemon)
    start_daemon
    ;;
  stop)
    pkill -f "cli.js --port $OD_DAEMON_PORT" 2>/dev/null || true
    pkill -f "next dev.*$OD_WEB_PORT" 2>/dev/null || true
    echo "stopped"
    ;;
  status)
    echo -n "daemon: "; curl -sf "http://127.0.0.1:$OD_DAEMON_PORT/api/health" 2>/dev/null && echo "" || echo "not running"
    echo -n "web:    "; curl -sf -o /dev/null -w "%{http_code}\n" "http://127.0.0.1:$OD_WEB_PORT" 2>/dev/null || echo "not running"
    ;;
  logs)
    tail -f /tmp/od-daemon.log
    ;;
  url)
    echo "http://127.0.0.1:$OD_WEB_PORT"
    ;;
  *)
    echo "Usage: od-preview {start|daemon|stop|status|logs|url}"
    exit 1
    ;;
esac
