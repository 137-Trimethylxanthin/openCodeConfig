      "reasoningSummary": "detailed",
      "steps": 26,
      "textVerbosity": "medium",
      "variant": "high"
    },
    "plan": {
      "description": "Read-only planning workflow for changes that genuinely cross components, alter data contracts, or require migration and rollback design.",
      "mode": "primary",
      "model": "openai/gpt-5.6-sol",
      "permission": {
        "bash": "deny",
        "edit": "deny",
