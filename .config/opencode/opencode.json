{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "browser": {
      "description": "Read-only browser, network, console, accessibility, and UX verification. Uses one specialist by default.",
      "mode": "primary",
      "model": "openai/gpt-5.6-terra",
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "external_directory": "deny",
        "playwright_*": "allow",
        "skill": {
          "*": "deny",
          "repo-onboarding": "allow",
          "verification-gate": "allow"
        },
        "task": {
          "*": "deny",
          "browser-checker": "allow",
          "designer": "allow",
          "researcher": "allow",
          "tester": "allow"
        }
      },
      "prompt": "{file:prompts/browser.txt}",
      "reasoningEffort": "high",
      "reasoningSummary": "auto",
      "steps": 18,
      "textVerbosity": "medium",
      "variant": "high"
    },
    "build": {
      "description": "Default direct coding workflow. Solves bounded work itself and escalates to at most one narrowly triggered specialist for ordinary tasks.",
      "mode": "primary",
      "model": "openai/gpt-5.6-terra",
      "permission": {
        "edit": "allow",
        "external_directory": "deny",
        "skill": {
          "*": "deny",
          "agent-handoff": "allow",
          "lean-ctx": "allow",
          "repo-onboarding": "allow",
          "safe-refactor": "allow",
          "systematic-debugging": "allow",
          "verification-gate": "allow"
        },
        "task": {
          "*": "deny",
          "debugger": "allow",
          "designer": "allow",
          "explore": "allow",
          "researcher": "allow",
          "reviewer": "allow",
          "security-review": "allow",
          "setup-maintainer": "allow"
        }
      },
      "prompt": "{file:prompts/build.txt}",
      "reasoningEffort": "high",
      "reasoningSummary": "auto",
      "steps": 20,
      "textVerbosity": "medium",
      "variant": "high"
    },
    "compaction": {
      "model": "openai/gpt-5.6-terra",
      "reasoningEffort": "medium",
      "textVerbosity": "low",
      "variant": "medium"
    },
    "ctf": {
      "description": "Authorized CTF and lab coordination manager that delegates hands-on investigation and commands within confirmed scope.",
      "mode": "primary",
      "model": "openai/gpt-5.6-sol",
      "permission": {
        "bash": "deny",
