      "prompt": "{file:prompts/ctf.txt}",
      "reasoningEffort": "xhigh",
      "reasoningSummary": "detailed",
      "steps": 32,
      "textVerbosity": "medium",
      "variant": "xhigh"
    },
    "docs": {
      "description": "Verified documentation workflow. Uses a specialist only for a distinct research, writing, or publication-review unit.",
