  "autoupdate": "notify",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 16000
  },
  "default_agent": "build",
  "mcp": {
    "context7": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "gh_grep": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "lean-ctx": {
      "command": [
        "/home/sitter/.local/bin/lean-ctx"
      ],
      "enabled": true,
      "type": "local"
    },
    "playwright": {
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@0.0.75"
      ],
      "enabled": false,
      "timeout": 30000,
      "type": "local"
    },
    "semgrep": {
      "command": [
        "semgrep",
        "mcp"
      ],
      "enabled": false,
      "timeout": 60000,
      "type": "local"
    }
  },
  "model": "openai/gpt-5.6-terra",
  "permission": {
    "*": "ask",
    "bash": "deny",
    "context7_*": "deny",
    "doom_loop": "ask",
    "edit": "ask",
    "external_directory": "deny",
    "fetch_*": "deny",
    "gh_grep_*": "deny",
    "glob": "deny",
    "grep": "deny",
    "list": "allow",
    "lsp": "allow",
    "playwright_*": "deny",
    "question": "allow",
    "read": "deny",
    "semgrep_*": "deny",
    "skill": {
      "*": "deny"
    },
    "task": "deny",
    "todowrite": "allow",
    "webfetch": "ask",
    "websearch": "ask"
  },
