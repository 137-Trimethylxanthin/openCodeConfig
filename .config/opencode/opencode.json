{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.6-terra",
  "small_model": "openai/gpt-5.6-luna",
  "default_agent": "build",
  "enabled_providers": ["openai"],
  "autoupdate": "notify",
  "share": "disabled",
  "subagent_depth": 1,
  "tool_output": {
    "max_lines": 800,
    "max_bytes": 40000
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 16000
  },
  "watcher": {
    "ignore": [
      "**/.git/**",
      "**/node_modules/**",
      "**/.next/**",
      "**/dist/**",
      "**/build/**",
      "**/target/**",
      "**/.venv/**",
      "**/__pycache__/**",
      "**/.gradle/**",
      "**/.idea/**"
    ]
  },
  "instructions": ["AGENTS.md"],
  "provider": {
    "openai": {
      "models": {
        "gpt-5.6-sol": {
          "options": {
            "reasoningEffort": "xhigh",
            "reasoningSummary": "detailed",
            "textVerbosity": "medium",
            "include": ["reasoning.encrypted_content"],
            "store": false
          },
          "variants": {
            "medium": {"reasoningEffort": "medium", "reasoningSummary": "auto", "textVerbosity": "medium"},
            "high": {"reasoningEffort": "high", "reasoningSummary": "detailed", "textVerbosity": "medium"},
            "xhigh": {"reasoningEffort": "xhigh", "reasoningSummary": "detailed", "textVerbosity": "medium"},
            "max": {"reasoningEffort": "max", "reasoningSummary": "detailed", "textVerbosity": "medium"},
            "none": {"disabled": true},
            "minimal": {"disabled": true},
            "low": {"disabled": true},
            "fast": {"disabled": true}
          }
        },
        "gpt-5.6-terra": {
          "options": {
            "reasoningEffort": "high",
            "reasoningSummary": "auto",
            "textVerbosity": "medium",
            "include": ["reasoning.encrypted_content"],
            "store": false
          },
          "variants": {
            "medium": {"reasoningEffort": "medium", "reasoningSummary": "auto", "textVerbosity": "medium"},
            "high": {"reasoningEffort": "high", "reasoningSummary": "auto", "textVerbosity": "medium"},
            "xhigh": {"reasoningEffort": "xhigh", "reasoningSummary": "detailed", "textVerbosity": "medium"},
            "max": {"reasoningEffort": "max", "reasoningSummary": "detailed", "textVerbosity": "medium"},
            "none": {"disabled": true},
            "minimal": {"disabled": true},
            "low": {"disabled": true},
            "fast": {"disabled": true}
          }
        },
        "gpt-5.6-luna": {
          "options": {
            "reasoningEffort": "medium",
            "reasoningSummary": "auto",
            "textVerbosity": "low",
            "include": ["reasoning.encrypted_content"],
            "store": false
          },
          "variants": {
            "medium": {"reasoningEffort": "medium", "reasoningSummary": "auto", "textVerbosity": "low"},
            "high": {"reasoningEffort": "high", "reasoningSummary": "auto", "textVerbosity": "medium"},
            "xhigh": {"reasoningEffort": "xhigh", "reasoningSummary": "detailed", "textVerbosity": "medium"},
            "max": {"reasoningEffort": "max", "reasoningSummary": "detailed", "textVerbosity": "medium"},
            "none": {"disabled": true},
            "minimal": {"disabled": true},
            "low": {"disabled": true},
            "fast": {"disabled": true}
          }
        }
      }
    }
  },
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      ".env": "deny",
      ".env.*": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/*credentials*": "ask",
      "**/*secret*": "ask",
      "**/*.pem": "ask",
      "**/*.key": "ask"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "skill": {"*": "deny"},
    "todowrite": "allow",
    "question": "allow",
    "task": "allow",
    "webfetch": "ask",
    "websearch": "ask",
    "external_directory": "deny",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git push*": "ask",
      "git reset --hard*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "git ls-files*": "allow",
      "git rev-parse*": "allow",
      "pwd": "allow",
      "ls*": "allow",
      "tree*": "allow",
      "rg *": "allow",
      "fd *": "allow",
      "find *": "allow",
      "wc *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "npm test*": "allow",
      "npm run test*": "allow",
      "npm run lint*": "allow",
      "npm run typecheck*": "allow",
      "pnpm test*": "allow",
      "pnpm lint*": "allow",
      "bun test*": "allow",
      "cargo test*": "allow",
      "cargo check*": "allow",
      "go test*": "allow",
      "go vet*": "allow",
      "pytest*": "allow",
      "python -m pytest*": "allow",
      "ruff check*": "allow",
      "biome check*": "allow",
      "shellcheck *": "allow",
      "shfmt -d *": "allow",
      "./gradlew test*": "allow",
      "./gradlew lint*": "allow",
      "sudo *": "deny",
      "sudo": "deny",
      "doas *": "deny",
      "su *": "deny",
      "rm -rf *": "deny",
      "rm -fr *": "deny",
      "git clean *": "deny",
      "git push --force*": "deny",
      "git push -f*": "deny"
    },
    "context7_*": "deny",
    "gh_grep_*": "deny",
    "fetch_*": "deny",
    "playwright_*": "deny",
    "semgrep_*": "deny"
  },
  "agent": {
    "build": {
      "description": "Primary implementation orchestrator. Delegates research, exploration, testing, and independent review based on task complexity.",
      "mode": "primary",
      "model": "openai/gpt-5.6-terra",
      "variant": "high",
      "reasoningEffort": "high",
      "reasoningSummary": "auto",
      "textVerbosity": "medium",
      "steps": 32,
      "prompt": "{file:prompts/build.txt}",
      "permission": {
        "edit": "allow",
        "external_directory": "deny",
        "skill": {
          "*": "deny",
          "repo-onboarding": "allow",
          "systematic-debugging": "allow",
          "verification-gate": "allow",
          "safe-refactor": "allow",
          "agent-handoff": "allow"
        },
        "task": {
          "*": "deny",
          "explore": "allow",
          "scout": "allow",
          "architect": "allow",
          "implementer": "allow",
          "debugger": "allow",
          "tester": "allow",
          "reviewer": "allow",
          "spec-reviewer": "allow",
          "test-strategist": "allow",
          "skeptic": "allow",
          "simplicity-reviewer": "allow",
          "performance-reviewer": "allow",
          "security-review": "allow",
          "researcher": "allow",
          "docs-writer": "allow",
          "infra-reviewer": "allow",
          "sysadmin": "allow",
          "ctf-lead": "allow",
          "setup-maintainer": "allow"
        }
      }
    },
    "plan": {
      "description": "Read-only planning and architecture orchestrator for large, uncertain, or high-impact changes.",
      "mode": "primary",
      "model": "openai/gpt-5.6-sol",
      "variant": "xhigh",
      "reasoningEffort": "xhigh",
      "reasoningSummary": "detailed",
      "textVerbosity": "medium",
      "steps": 22,
      "prompt": "{file:prompts/plan.txt}",
      "permission": {
        "edit": "deny",
        "external_directory": "deny",
        "bash": "deny",
        "skill": {"*": "deny", "repo-onboarding": "allow", "evidence-research": "allow", "agent-handoff": "allow"},
        "task": {"*": "deny", "explore": "allow", "scout": "allow", "architect": "allow", "researcher": "allow", "skeptic": "allow", "security-review": "allow", "performance-reviewer": "allow"}
      }
    },
    "project": {
      "description": "Leads high-impact, cross-cutting implementation with independent review and rollback planning.",
      "mode": "primary",
      "model": "openai/gpt-5.6-sol",
      "variant": "xhigh",
      "reasoningEffort": "xhigh",
      "reasoningSummary": "detailed",
      "textVerbosity": "medium",
      "steps": 44,
      "prompt": "{file:prompts/project.txt}",
      "permission": {"edit": "allow", "external_directory": "deny", "task": {"*": "deny", "explore": "allow", "repo-analyst": "allow", "architect": "allow", "implementer": "allow", "debugger": "allow", "tester": "allow", "reviewer": "allow", "spec-reviewer": "allow", "test-strategist": "allow", "skeptic": "allow", "simplicity-reviewer": "allow", "performance-reviewer": "allow", "security-review": "allow", "researcher": "allow", "docs-writer": "allow", "infra-reviewer": "allow", "designer": "allow"}}},
    "research": {
      "description": "Researches current APIs, technical questions, and implementation choices using primary sources.",
      "mode": "primary",
      "model": "openai/gpt-5.6-terra",
      "variant": "high",
      "reasoningEffort": "high",
      "reasoningSummary": "auto",
      "textVerbosity": "medium",
      "steps": 24,
      "prompt": "{file:prompts/research.txt}",
      "permission": {"edit": "deny", "bash": "deny", "external_directory": "deny", "webfetch": "allow", "websearch": "allow", "context7_*": "allow", "gh_grep_*": "allow", "task": {"*": "deny", "scout": "allow", "researcher": "allow", "work-research": "allow", "repo-analyst": "allow"}}},
    "browser": {
      "description": "Verifies browser flows, console output, network behavior, and accessibility.",
      "mode": "primary",
      "model": "openai/gpt-5.6-terra",
      "variant": "high",
      "reasoningEffort": "high",
      "reasoningSummary": "auto",
      "textVerbosity": "medium",
      "steps": 24,
      "prompt": "{file:prompts/browser.txt}",
      "permission": {"edit": "deny", "bash": "deny", "external_directory": "deny", "playwright_*": "allow", "task": {"*": "deny", "browser-checker": "allow", "designer": "allow", "tester": "allow", "researcher": "allow"}}},
    "security": {
      "description": "Performs defensive security review of code, configuration, and trust boundaries.",
      "mode": "primary",
      "model": "openai/gpt-5.6-sol",
      "variant": "max",
      "reasoningEffort": "max",
      "reasoningSummary": "detailed",
      "textVerbosity": "medium",
      "steps": 36,
      "prompt": "{file:prompts/security.txt}",
      "permission": {"edit": "deny", "bash": "deny", "external_directory": "deny", "semgrep_*": "allow", "task": {"*": "deny", "security-review": "allow", "forensics": "allow", "reverse-engineer": "allow", "incident-review": "allow", "researcher": "allow", "repo-analyst": "allow"}}},
    "ctf": {
      "description": "Coordinates authorized CTF and lab work across web, crypto, reversing, pwn, and forensics.",
      "mode": "primary",
      "model": "openai/gpt-5.6-sol",
      "variant": "max",
      "reasoningEffort": "max",
      "reasoningSummary": "detailed",
      "textVerbosity": "medium",
      "steps": 44,
      "prompt": "{file:prompts/ctf.txt}",
      "permission": {"edit": "ask", "bash": {"*": "ask", "sudo *": "deny", "sudo": "deny", "doas *": "deny", "su *": "deny", "rm -rf *": "deny", "rm -fr *": "deny", "git clean *": "deny", "git push*": "deny"}, "external_directory": "deny", "semgrep_*": "allow", "task": {"*": "deny", "ctf-lead": "allow", "forensics": "allow", "reverse-engineer": "allow", "researcher": "allow", "security-review": "allow"}}},
    "infra": {
      "description": "Plans and reviews infrastructure, containers, networking, deployment, and rollback.",
      "mode": "primary",
      "model": "openai/gpt-5.6-sol",
      "variant": "xhigh",
      "reasoningEffort": "xhigh",
      "reasoningSummary": "detailed",
      "textVerbosity": "medium",
      "steps": 38,
      "prompt": "{file:prompts/infra.txt}",
      "permission": {"edit": "ask", "bash": {"*": "ask", "sudo *": "deny", "sudo": "deny", "doas *": "deny", "su *": "deny", "rm -rf *": "deny", "rm -fr *": "deny", "git clean *": "deny", "git push*": "deny"}, "external_directory": "deny", "task": {"*": "deny", "infra-reviewer": "allow", "sysadmin": "allow", "incident-review": "allow", "security-review": "allow", "researcher": "allow"}}},
    "docs": {
      "description": "Creates and maintains precise technical documentation from verified behavior.",
      "mode": "primary",
      "model": "openai/gpt-5.6-luna",
      "variant": "high",
      "reasoningEffort": "high",
      "reasoningSummary": "auto",
      "textVerbosity": "medium",
      "steps": 22,
      "prompt": "{file:prompts/docs.txt}",
      "permission": {"edit": "ask", "bash": "deny", "external_directory": "deny", "context7_*": "allow", "task": {"*": "deny", "docs-writer": "allow", "work-research": "allow", "researcher": "allow", "reviewer": "allow"}}},
    "explore": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-luna",
      "variant": "medium",
      "reasoningEffort": "medium",
      "reasoningSummary": "auto",
      "textVerbosity": "low",
      "steps": 8,
      "permission": {"edit": "deny", "bash": "deny", "task": "deny", "external_directory": "deny", "skill": {"*": "deny", "repo-onboarding": "allow"}}
    },
    "scout": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-luna",
      "variant": "high",
      "reasoningEffort": "high",
      "reasoningSummary": "auto",
      "textVerbosity": "low",
      "steps": 10,
      "permission": {"edit": "deny", "bash": "deny", "task": "deny", "external_directory": "deny", "skill": {"*": "deny", "evidence-research": "allow"}}
    },
    "general": {
      "mode": "subagent",
      "model": "openai/gpt-5.6-terra",
      "variant": "high",
      "reasoningEffort": "high",
      "reasoningSummary": "auto",
      "textVerbosity": "medium",
      "steps": 14
    },
    "title": {"model": "openai/gpt-5.6-luna", "variant": "medium", "reasoningEffort": "medium", "textVerbosity": "low"},
    "summary": {"model": "openai/gpt-5.6-luna", "variant": "medium", "reasoningEffort": "medium", "textVerbosity": "low"},
    "compaction": {"model": "openai/gpt-5.6-terra", "variant": "high", "reasoningEffort": "high", "textVerbosity": "low"}
  },
  "mcp": {
    "context7": {"type": "remote", "url": "https://mcp.context7.com/mcp", "enabled": false},
    "gh_grep": {"type": "remote", "url": "https://mcp.grep.app", "enabled": false},
    "playwright": {"type": "local", "command": ["npx", "-y", "@playwright/mcp@0.0.75"], "enabled": false, "timeout": 30000},
    "semgrep": {"type": "local", "command": ["semgrep", "mcp"], "enabled": false, "timeout": 60000}
  },
  "plugin": []
}
